[Unit]
Description=Pi-Nisse Webchat (Uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=kjelle
WorkingDirectory=/home/kjelle/webchat
ExecStart=/home/kjelle/webchat/bin/uvicorn app:app \
  --host 0.0.0.0 \
  --port 3080 \
  --ssl-keyfile /home/kjelle/webchat/key.pem \
  --ssl-certfile /home/kjelle/webchat/cert.pem
Restart=on-failure
Environment="PATH=/home/kjelle/webchat/bin"

[Install]
WantedBy=multi-user.target
